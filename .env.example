# TalkBank credentials (register at https://class.talkbank.org)
TALKBANK_EMAIL=your@email.com
TALKBANK_PASSWORD=yourpassword

# STT Engine API Keys
GEMINI_API_KEY=your-gemini-api-key
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# AWS Bedrock (for speaker classification LLM)
AWS_REGION=us-east-1
BEDROCK_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# Engine Configuration
DEFAULT_STT_ENGINE=gemini_pro
GEMINI_STT_MODEL=gemini-2.5-pro
GEMINI_31_PRO_MODEL=gemini-3.1-pro-preview
GEMINI_35_FLASH_MODEL=gemini-3.5-flash
GEMINI_STT_TEMPERATURE=0.0
GEMINI_STT_TOP_P=0.0
GEMINI_STT_MAX_OUTPUT_TOKENS=65536
GEMINI_STT_POLL_TIMEOUT=600
GEMINI_STT_POLL_INTERVAL=10
GEMINI_STT_HTTP_TIMEOUT=600000
GEMINI_STT_UPLOAD_RETRIES=2
GEMINI_STT_UPLOAD_RETRY_DELAY=15

# ElevenLabs Configuration
SEGMENT_PAUSE_THRESHOLD_MS=2000
SEGMENT_MAX_DURATION_SEC=30.0
ELEVENLABS_ROLE_CLASSIFICATION_RETRIES=3
